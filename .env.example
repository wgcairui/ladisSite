# 部署时复制为 .env 并按需修改
# docker compose 默认会读取同目录下的 .env

# 后端 API 基址（nuxt.config.ts 读 process.env.NUXT_SERVER）
NUXT_SERVER=https://www.ladishb.com/site

# 公司名（用于 sitemap 路由生成时作 name header）
NAME=湖北雷迪司

# sitemap hostname
HOSTNAME=www.ladishb.com


# 可选：浏览器端/服务端 baseURL
BROWSER_BASE_URL=
BASE_URL=

# 宿主机端口（容器内固定 80）
HTTP_PORT=80
